DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/truthpuzzle
REDIS_URL=redis://redis:6379/0
SEARCH_ENGINE_URL=http://meilisearch:7700
SEARCH_ENGINE_API_KEY=

LLM_PROVIDER=ollama
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# If using docker-compose --profile ollama, use http://ollama:11434.
# If using host Ollama, use http://host.docker.internal:11434.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

MBFC_RAPIDAPI_KEY=

COLLECT_INTERVAL_MINUTES=15
REGULAR_COLLECT_INTERVAL_MINUTES=60
HOT_EVENT_COLLECT_INTERVAL_MINUTES=15
HOT_EVENT_THRESHOLD=70
GOOGLE_NEWS_ENABLED=true
MAX_CONCURRENT_SCRAPERS=10

CLUSTER_SIMILARITY_THRESHOLD=0.75
CLUSTER_TIME_WINDOW_HOURS=72
CONSENSUS_THRESHOLD=0.70
REANALYZE_THRESHOLD=0.10

BACKEND_CORS_ORIGINS=http://localhost:3000,http://frontend:3000

VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
